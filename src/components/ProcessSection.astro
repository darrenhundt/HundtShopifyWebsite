---
const steps = [
  {
    n:    "01",
    name: "Free 5-min Loom scoping",
    desc: "Send me your storefront URL and what you're trying to build or fix. I'll record a quick Loom with my read on the work before we talk price.",
  },
  {
    n:    "02",
    name: "Scoped fixed-bid quote",
    desc: "One-page scope, fixed price, weekly demos. No retainers, no surprise change orders.",
  },
  {
    n:    "03",
    name: "Work in your channel",
    desc: "Slack, email, text, iMessage — whatever you're already using. No new tools, no new logins.",
  },
  {
    n:    "04",
    name: "Hand-off + 2 weeks support",
    desc: "Documented in your repo. Loom walkthrough of every change. Bug fixes for two weeks, free.",
  },
];
---

<section class="sec sec-feature" id="process" aria-labelledby="process-heading">
  <div class="container">

    <div class="feature-head">
      <div class="sec-eyebrow">The human advantage</div>
      <h2 class="feature-h" id="process-heading">
        One engineer.
        <span class="feature-mute">No agency. No PM layer. No junior on the code.</span>
      </h2>
    </div>

    <div class="process">
      {steps.map((s) => (
        <div class="process-step">
          <div class="process-num">{s.n}</div>
          <div class="process-name">{s.name}</div>
          <div class="process-desc">{s.desc}</div>
        </div>
      ))}
    </div>

  </div>
</section>
