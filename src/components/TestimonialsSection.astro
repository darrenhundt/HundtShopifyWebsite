---
const testimonials = [
  {
    avatar: "SS",
    name:   "Sara Sortzi",
    role:   "Sequel Supplements",
    quote:
      "Darren was great! I'd give more than 5 stars if I could. Great communicator and very quick with my needed changes. Would recommend and hire again!",
  },
  {
    avatar: "AG",
    name:   "Anthony Gucciardi",
    role:   "President · Of The Ancients",
    quote:
      "Darren is excellent, highly recommend working with him. His work is done with a high quality standard, and professionally. A pleasure to communicate with, and goes above and beyond. 100% you should hire Darren for your next project.",
  },
  {
    avatar: "SM",
    name:   "Shawn Moreau",
    role:   "Owner · Beard Coalition",
    quote:
      "He thinks strategically and was able to filter through what I thought I needed and got down to the crux of my issue. He finished in even less time than he thought and billed me fairly. HIGHLY recommend working with Darren.",
  },
];
---

<section class="sec" id="words" aria-labelledby="words-heading">
  <div class="container">

    <div class="sec-head">
      <div>
        <div class="sec-eyebrow">Words from founders</div>
        <h2 id="words-heading">
          What it sounds like when there's no agency between you and the work.
        </h2>
      </div>
    </div>

    <div class="t-grid">
      {testimonials.map((t) => (
        <article class="t-card">
          <div class="t-quote">{t.quote}</div>
          <div class="t-author">
            <div class="t-avatar" aria-hidden="true">{t.avatar}</div>
            <div>
              <div class="t-name">{t.name}</div>
              <div class="t-role">{t.role}</div>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
