---
import { getCollection } from "astro:content";

const all = await getCollection("case-studies");
const cases = all.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
const siteOrigin = Astro.site?.href?.replace(/\/$/, "") ?? "https://darrenshopify.dev";
---

<section class="sec" id="work" aria-labelledby="work-heading">
  <div class="container">

    <div class="sec-head">
      <div>
        <div class="sec-eyebrow">Selected work</div>
        <h2 id="work-heading">Real stores. Real outcomes.</h2>
      </div>
    </div>

    <div class="case-grid">
      {cases.map((entry, ci) => {
        const c = entry.data;
        const slug = entry.slug;
        const blurb = `${c.title.toUpperCase()}
Stack: ${c.stack.join(" / ")}
Outcome: ${c.stats.map((s) => `${s.k} ${s.v}`).join(", ")}
Read: ${siteOrigin}/work/${slug}`;

        return (
          <article class="case-card">

            <div class="case-thumb ph" role="img" aria-label={`${c.title} — hero image placeholder`}>
              <div class="ph-caption">
                <span>{c.imageCaption ?? `${slug}-hero.png`}</span>
                <span>{c.stack.slice(0, 2).join(" · ")}</span>
              </div>
            </div>

            <div class="case-body">
              <div class="case-title">{c.title}</div>
              <div class="ps-row">
                <div class="ps-key">Problem</div>
                <div class="ps-val">{c.problem}</div>
              </div>
              <div class="ps-row">
                <div class="ps-key">Technical win</div>
                <div class="ps-val">{c.technicalWin}</div>
              </div>
            </div>

            <div class="case-stats">
              {c.stats.map((s, i) => (
                <div class={`case-stat${i === 0 ? " primary" : ""}`}>
                  <div class="k">{s.k}</div>
                  <div class="v">{s.v}</div>
                </div>
              ))}
            </div>

            <div class="case-actions">
              <div class="left">{c.status}</div>
              <div class="right">
                <button
                  type="button"
                  class="copy-btn"
                  data-copy={blurb}
                  aria-label={`Copy Upwork blurb for ${c.title}`}
                >
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" width="12" height="12" aria-hidden="true">
                    <rect x="4" y="4" width="9" height="9" rx="1.5"></rect>
                    <path d="M3 11V4a1 1 0 0 1 1-1h7"></path>
                  </svg>
                  Copy blurb
                </button>
                <a
                  href={`/work/${slug}`}
                  class="copy-btn"
                  aria-label={`Read case study: ${c.title}`}
                >
                  Read case
                  <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" width="12" height="12" aria-hidden="true">
                    <path d="M3 8h10m-4-4 4 4-4 4"></path>
                  </svg>
                </a>
              </div>
            </div>

          </article>
        );
      })}
    </div>

  </div>
</section>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn[data-copy]").forEach((btn) => {
    const svgCopy = btn.querySelector("svg")!.outerHTML;
    const svgCheck = `<svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" width="12" height="12" aria-hidden="true"><path d="m3 8.5 3.5 3.5L13 5"></path></svg>`;

    btn.addEventListener("click", () => {
      const text = btn.dataset.copy ?? "";
      try {
        if (navigator.clipboard && window.isSecureContext !== false) {
          navigator.clipboard.writeText(text).catch(() => {});
        }
      } catch (_) {}

      btn.classList.add("copied");
      btn.innerHTML = `${svgCheck} Copied`;
      btn.setAttribute("aria-label", btn.getAttribute("aria-label")!.replace("Copy", "Copied"));

      setTimeout(() => {
        btn.classList.remove("copied");
        btn.innerHTML = `${svgCopy} Copy blurb`;
        btn.setAttribute("aria-label", btn.getAttribute("aria-label")!.replace("Copied", "Copy"));
      }, 1600);
    });
  });
</script>
