---
import { SERVICE_CARDS, PRICING_CALLOUT } from "@/data/custom-apps";
---

<section class="sec sec-custom-apps" id="custom-apps" aria-labelledby="custom-apps-heading">
  <div class="container">

    <div class="sec-head">
      <div>
        <div class="sec-eyebrow">Custom apps</div>
        <h2 id="custom-apps-heading">A custom Shopify app for your exact problem.</h2>
        <p class="custom-apps-sub">One price. No monthly fee. No features you'll never use.</p>
      </div>
    </div>

    <p class="custom-apps-lede">
      Most Shopify apps charge you every month for functionality built for thousands of stores.
      I build the exact tool your store needs — nothing more — deployed directly to your Shopify
      admin with no external servers, no devops, and no ongoing costs passed to you.
    </p>

    <!-- Service cards: same grid/card pattern as .process -->
    <div class="process custom-apps-grid">
      {SERVICE_CARDS.map((card) => (
        <div class="process-step">
          <div class="process-num">{card.n}</div>
          <div class="process-name">{card.title}</div>
          <div class="process-desc">{card.body}</div>
        </div>
      ))}
    </div>

    <!-- Pricing callout: visually distinct using accent-soft background + accent border -->
    <div class="custom-apps-callout" aria-label="Pricing rationale">
      <div class="custom-apps-callout-inner">
        <div class="custom-apps-callout-icon" aria-hidden="true">$1</div>
        <div>
          <h3 class="custom-apps-callout-h">{PRICING_CALLOUT.heading}</h3>
          <p class="custom-apps-callout-body">{PRICING_CALLOUT.body}</p>
        </div>
      </div>
    </div>

    <div class="custom-apps-cta">
      <a href="/#contact" class="btn btn-primary">
        Tell me what you're paying for monthly
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" width="14" height="14" aria-hidden="true">
          <path d="M3 8h10m-4-4 4 4-4 4"></path>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .custom-apps-sub {
    font-family: var(--mono);
    font-size: 13px;
    color: var(--fg-mute);
    margin: 8px 0 0;
    letter-spacing: -0.005em;
  }

  .custom-apps-lede {
    color: var(--fg-mute);
    font-size: 16px;
    line-height: 1.65;
    max-width: 720px;
    margin: 0 0 48px;
  }

  /* 2×2 on desktop; inherits .process responsive rules for ≤1080px and ≤768px */
  .custom-apps-grid {
    grid-template-columns: repeat(2, 1fr) !important;
    margin-bottom: 28px;
  }

  /* Pricing callout: accent-tinted background matches existing .tut-callout language */
  .custom-apps-callout {
    background: var(--accent-soft);
    border: 1px solid var(--accent-line);
    border-radius: 14px;
    padding: 32px 36px;
    margin-bottom: 36px;
  }

  .custom-apps-callout-inner {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .custom-apps-callout-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: var(--accent);
    color: #1b0f04;
    display: grid;
    place-items: center;
    font-family: var(--mono);
    font-weight: 700;
    font-size: 13px;
  }

  .custom-apps-callout-h {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 2px 0 8px;
  }

  .custom-apps-callout-body {
    color: var(--fg-mute);
    font-size: 14px;
    line-height: 1.65;
    margin: 0;
    max-width: 700px;
  }

  .custom-apps-cta {
    display: flex;
  }

  @media (max-width: 768px) {
    .custom-apps-callout {
      padding: 24px 22px;
    }

    .custom-apps-callout-inner {
      flex-direction: column;
      gap: 14px;
    }
  }
</style>
