---
import { getCollection } from "astro:content";
import {
  BLOG_CLUSTERS,
  CLUSTER_ORDER,
  clusterFilterHref,
  findPostByTitle,
  isPublished,
} from "@/lib/blog";

const allPosts = await getCollection("blog");
const published = allPosts.filter(isPublished);
---

<section class="sec" id="topics" aria-labelledby="topics-heading">
  <div class="container">

    <div class="sec-head">
      <div>
        <div class="sec-eyebrow">Knowledge hub</div>
        <h2 id="topics-heading">Skimmable technical writing on the things I actually ship.</h2>
      </div>
      <a href="/blog" class="sec-link">
        All articles
        <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" width="13" height="13" aria-hidden="true">
          <path d="M5 11 11 5m0 0H6m5 0v5"></path>
        </svg>
      </a>
    </div>

    <div class="cluster-grid">
      {CLUSTER_ORDER.map((id) => {
        const c = BLOG_CLUSTERS[id];
        const previews = c.seedArticles.slice(0, 2);
        const publishedInCluster = published.filter((p) => p.data.cluster === id).length;

        return (
          <div class="cluster">
            <a href={clusterFilterHref(id)} class="cluster-main-link">
              <div class="cluster-h">
                <span class="cluster-num">{c.n}</span>
                <span class="cluster-count">
                  {publishedInCluster > 0
                    ? `${publishedInCluster} published`
                    : `${c.seedArticles.length} planned`}
                </span>
              </div>
              <div class="cluster-name">{c.name}</div>
              <div class="cluster-desc">{c.description}</div>
            </a>
            <div class="cluster-articles">
              {previews.map((title) => {
                const post = findPostByTitle(allPosts, title);
                const href = post && isPublished(post)
                  ? `/blog/${post.slug}`
                  : clusterFilterHref(id);

                return (
                  <a href={href}>
                    <span class="arrow" aria-hidden="true">→</span>
                    {title}
                  </a>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<style>
  .cluster-main-link {
    display: flex;
    flex-direction: column;
    gap: 14px;
    text-decoration: none;
    color: inherit;
  }
  .cluster-main-link:hover .cluster-name {
    color: var(--accent);
  }
</style>
