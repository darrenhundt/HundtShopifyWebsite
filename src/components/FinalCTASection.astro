---
import siteConfig from "@/data/site-config.json";

const email = "darren@darrenshopify.dev";

const { slotsLeft, quarterLabel } = siteConfig;

const slotsHeadline =
  slotsLeft === 1
    ? "One sprint slot left. Runs 3–4 weeks."
    : slotsLeft === 2
      ? "Two sprint slots left. Both are 3–4 weeks."
      : `${slotsLeft} sprint slots left. Each is 3–4 weeks.`;

const sprintMailto = `mailto:${email}?subject=${encodeURIComponent("Sprint application")}`;
const emailMailto = `mailto:${email}`;
---

<section class="sec sec--flush-top" id="contact" aria-labelledby="contact-heading">
  <div class="container">
    <div class="final-cta">
      <div>
        <div class="sec-eyebrow">{quarterLabel} · booking</div>
        <h3 id="contact-heading">{slotsHeadline}</h3>
        <p>
          Send me your storefront URL and the one number you wish was better. I'll send back
          a 5-min Loom diagnosing the actual bottleneck — free, before either of us commits
          to anything.
        </p>
      </div>
      <div class="actions">
        <a href={sprintMailto} class="btn btn-primary">
          Apply for a sprint
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.4" width="13" height="13" aria-hidden="true">
            <path d="M3 8h10m-4-4 4 4-4 4"></path>
          </svg>
        </a>
        <a href={emailMailto} class="btn btn-ghost">
          Email me directly
        </a>
      </div>
    </div>
  </div>
</section>
