---
import Nav from "@/components/Nav.astro";
import Footer from "@/components/Footer.astro";
import "@fontsource-variable/inter";
import "@fontsource-variable/jetbrains-mono";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogType?: "website" | "article";
  schema?: string;
}

const {
  title,
  description = "Solo Shopify engineer in North Texas. Performance, ADA compliance, and custom Liquid — delivered directly by the engineer writing the code.",
  noindex = false,
  ogType = "website",
  schema,
} = Astro.props;

const siteUrl = Astro.site?.href?.replace(/\/$/, "") ?? "https://darrenhundt.dev";
const canonicalURL =
  siteUrl + (Astro.url.pathname === "/" ? "" : Astro.url.pathname.replace(/\/$/, ""));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <title>{title}</title>

    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:image" content="https://darrenhundt.dev/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://darrenhundt.dev/og-image.png" />

    <!-- JSON-LD schema -->
    {schema && <script type="application/ld+json" set:html={schema} />}

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
